<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <Nullable>disable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UserSecretsId>d5fde5f3-74c2-4f6f-810d-92dae9978f31</UserSecretsId>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
        <DockerfileContext>..\..</DockerfileContext>
    </PropertyGroup>

    <ItemGroup>
        <!-- Version managed in Directory.Packages.props (CPM) -->
        <PackageReference Include="Asp.Versioning.Mvc.ApiExplorer"/>

        <PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets"/>

        <PackageReference Include="Swashbuckle.AspNetCore"/>
        <PackageReference Include="Swashbuckle.AspNetCore.Swagger"/>
        <PackageReference Include="Swashbuckle.AspNetCore.SwaggerGen"/>
        <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI"/>
        <PackageReference Include="Swashbuckle.AspNetCore.Filters"/>

        <PackageReference Include="Tnf.AspNetCore"/>
        <PackageReference Include="Tnf.AspNetCore.Security.FluigIdentity"/>
        <PackageReference Include="Tnf.SmartX"/>

        <PackageReference Include="Serilog"/>
        <PackageReference Include="Serilog.Extensions.Hosting"/>
        <PackageReference Include="Serilog.Settings.Configuration"/>
        <PackageReference Include="Serilog.Enrichers.Environment"/>
        <PackageReference Include="Serilog.Sinks.Async"/>
        <PackageReference Include="Serilog.Sinks.Console"/>
        <PackageReference Include="Tnf.SmartX.Security.FluigIdentity"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Tnf.SmartX.Domain\Tnf.SmartX.Domain.csproj"/>
        <ProjectReference Include="..\Tnf.SmartX.EntityFramework.PostgreSql\Tnf.SmartX.EntityFramework.PostgreSql.csproj"/>
    </ItemGroup>

</Project>
